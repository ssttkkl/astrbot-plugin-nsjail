[
  {
    "name": "管道",
    "command": "/nsjail echo hello | tr a-z A-Z",
    "expected": "HELLO",
    "category": "Shell"
  },
  {
    "name": "重定向",
    "command": "/nsjail echo err 2>&1",
    "expected": "err",
    "category": "Shell"
  },
  {
    "name": "变量",
    "command": "/nsjail X=123 && echo $X",
    "expected": "123",
    "category": "Shell"
  },
  {
    "name": "循环",
    "command": "/nsjail for i in 1 2 3; do echo $i; done",
    "expected": "1",
    "category": "Shell"
  },
  {
    "name": "条件",
    "command": "/nsjail if [ 1 -eq 1 ]; then echo yes; fi",
    "expected": "yes",
    "category": "Shell"
  },
  {
    "name": "命令替换",
    "command": "/nsjail echo $(expr 1 + 1)",
    "expected": "2",
    "category": "Shell"
  },
  {
    "name": "字符串处理",
    "command": "/nsjail echo 'hello world' | cut -d' ' -f1",
    "expected": "hello",
    "category": "Shell"
  },
  {
    "name": "grep过滤",
    "command": "/nsjail echo -e 'a\\nb\\nc' | grep b",
    "expected": "b",
    "category": "Shell"
  },
  {
    "name": "sed替换",
    "command": "/nsjail echo hello | sed 's/hello/hi/'",
    "expected": "hi",
    "category": "Shell"
  },
  {
    "name": "awk处理",
    "command": "/nsjail echo '1 2 3' | awk '{print $2}'",
    "expected": "2",
    "category": "Shell"
  },
  {
    "name": "xargs",
    "command": "/nsjail echo -e 'a\\nb' | xargs echo",
    "expected": "a b",
    "category": "Shell"
  },
  {
    "name": "tee命令",
    "command": "/nsjail echo test | tee f.txt",
    "expected": "test",
    "category": "Shell"
  },
  {
    "name": "basename",
    "command": "/nsjail basename /path/to/file.txt",
    "expected": "file.txt",
    "category": "Shell"
  },
  {
    "name": "dirname",
    "command": "/nsjail dirname /path/to/file",
    "expected": "/path/to",
    "category": "Shell"
  },
  {
    "name": "date命令",
    "command": "/nsjail date +%Y",
    "expected": "202",
    "category": "Shell"
  },
  {
    "name": "sleep命令",
    "command": "/nsjail sleep 1 && echo done",
    "expected": "done",
    "category": "Shell"
  },
  {
    "name": "true命令",
    "command": "/nsjail true && echo ok",
    "expected": "ok",
    "category": "Shell"
  },
  {
    "name": "false命令",
    "command": "/nsjail false || echo ok",
    "expected": "ok",
    "category": "Shell"
  },
  {
    "name": "test命令",
    "command": "/nsjail test -d /workspace && echo yes",
    "expected": "yes",
    "category": "Shell"
  },
  {
    "name": "which命令",
    "command": "/nsjail which python3",
    "expected": "/usr/bin/python3",
    "category": "Shell"
  },
  {
    "name": "进程信息",
    "command": "/nsjail ps aux | head -2",
    "expected": "PID",
    "category": "Shell"
  },
  {
    "name": "内存信息",
    "command": "/nsjail free -h 2>&1 || echo ok",
    "expected": "退出码",
    "category": "Shell"
  },
  {
    "name": "磁盘使用",
    "command": "/nsjail df -h . 2>&1",
    "expected": "退出码",
    "category": "Shell"
  },
  {
    "name": "环境变量列表",
    "command": "/nsjail env | grep PATH",
    "expected": "PATH",
    "category": "Shell"
  },
  {
    "name": "用户信息",
    "command": "/nsjail whoami",
    "expected": "退出码",
    "category": "Shell"
  },
  {
    "name": "主机名",
    "command": "/nsjail hostname",
    "expected": "退出码",
    "category": "Shell"
  },
  {
    "name": "时间戳",
    "command": "/nsjail date +%s",
    "expected": "17",
    "category": "Shell"
  },
  {
    "name": "随机数",
    "command": "/nsjail echo $RANDOM",
    "expected": "退出码",
    "category": "Shell"
  },
  {
    "name": "Shell函数定义",
    "command": "/nsjail bash -c 'func() { echo $((\\$1 * 2)); }; func 5'",
    "expected": "10",
    "category": "Shell"
  },
  {
    "name": "Shell数组操作",
    "command": "/nsjail bash -c 'arr=(a b c); echo \\${arr[1]}'",
    "expected": "b",
    "category": "Shell"
  },
  {
    "name": "Shell关联数组",
    "command": "/nsjail bash -c 'declare -A map; map[key]=value; echo \\${map[key]}'",
    "expected": "value",
    "category": "Shell"
  },
  {
    "name": "Shell字符串截取",
    "command": "/nsjail bash -c 'str=hello; echo \\${str:1:3}'",
    "expected": "ell",
    "category": "Shell"
  },
  {
    "name": "Shell参数展开",
    "command": "/nsjail bash -c 'x=test; echo \\${x:-default}'",
    "expected": "test",
    "category": "Shell"
  },
  {
    "name": "Shell进程替换",
    "command": "/nsjail bash -c 'diff <(echo a) <(echo b) || echo different'",
    "expected": "different",
    "category": "Shell"
  },
  {
    "name": "Shell后台任务",
    "command": "/nsjail bash -c 'sleep 0.1 & wait; echo done'",
    "expected": "done",
    "category": "Shell"
  },
  {
    "name": "Shell信号处理",
    "command": "/nsjail bash -c 'trap \"echo caught\" SIGTERM; kill -TERM \\$\\$ 2>/dev/null || echo caught'",
    "expected": "caught",
    "category": "Shell"
  },
  {
    "name": "Shell算术运算",
    "command": "/nsjail bash -c 'echo \\$((10 + 20 * 3))'",
    "expected": "70",
    "category": "Shell"
  },
  {
    "name": "Shell case语句",
    "command": "/nsjail bash -c 'x=2; case \\$x in 1) echo one;; 2) echo two;; esac'",
    "expected": "two",
    "category": "Shell"
  },
  {
    "name": "base64编码",
    "command": "/nsjail echo hello | base64",
    "expected": "aGVsbG8K",
    "category": "Shell"
  },
  {
    "name": "base64解码",
    "command": "/nsjail echo aGVsbG8K | base64 -d",
    "expected": "hello",
    "category": "Shell"
  },
  {
    "name": "URL编码",
    "command": "/nsjail python3 -c 'import urllib.parse; print(urllib.parse.quote(\"a b\"))'",
    "expected": "a%20b",
    "category": "Shell"
  },
  {
    "name": "十六进制",
    "command": "/nsjail echo hello | xxd -p",
    "expected": "68656c6c6f",
    "category": "Shell"
  },
  {
    "name": "数学计算-加法",
    "command": "/nsjail expr 100 + 200",
    "expected": "300",
    "category": "Shell"
  },
  {
    "name": "数学计算-乘法",
    "command": "/nsjail expr 25 \\* 4",
    "expected": "100",
    "category": "Shell"
  },
  {
    "name": "字符统计",
    "command": "/nsjail echo hello | wc -c",
    "expected": "6",
    "category": "Shell"
  },
  {
    "name": "单词统计",
    "command": "/nsjail echo 'a b c' | wc -w",
    "expected": "3",
    "category": "Shell"
  },
  {
    "name": "行号",
    "command": "/nsjail echo -e 'a\\nb' | nl",
    "expected": "1",
    "category": "Shell"
  }
