import asyncio
import os
import tempfile
import shutil
from astrbot.api.star import Context, Star
from astrbot.api import logger, AstrBotConfig
from .tools.execute_shell import ExecuteShellTool

class SandboxManager:
    """沙箱管理器"""
    def __init__(self):
        self.sandboxes = {}  # session_id -> sandbox_dir
    
    def create_sandbox(self, session_id: str) -> str:
        """创建沙箱目录"""
        if session_id in self.sandboxes:
            return self.sandboxes[session_id]
        
        sandbox_dir = tempfile.mkdtemp(prefix=f"nsjail_{session_id}_")
        self.sandboxes[session_id] = sandbox_dir
        logger.info(f"创建沙箱: {sandbox_dir}")
        return sandbox_dir
    
    def get_sandbox(self, session_id: str) -> str:
        """获取沙箱目录"""
        return self.sandboxes.get(session_id)
    
    def destroy_sandbox(self, session_id: str):
        """销毁沙箱"""
        sandbox_dir = self.sandboxes.pop(session_id, None)
        if sandbox_dir and os.path.exists(sandbox_dir):
            shutil.rmtree(sandbox_dir)
            logger.info(f"销毁沙箱: {sandbox_dir}")

class NsjailPlugin(Star):
    def __init__(self, context: Context, config: AstrBotConfig):
        super().__init__(context)
        self.config = config
        self.max_timeout = config.get("max_timeout", 60)
        self.sandbox_mgr = SandboxManager()
        
        # 创建工具实例并传入插件引用
        tool = ExecuteShellTool()
        tool.plugin_instance = self
        self.context.add_llm_tools(tool)
    
    async def execute_in_sandbox(self, session_id: str, command: str, timeout: int = 30) -> tuple[str, int]:
        """在沙箱中执行命令"""
        # 限制超时时间不超过全局配置
        timeout = min(timeout, self.max_timeout)
        
        sandbox_dir = self.sandbox_mgr.get_sandbox(session_id)
        if not sandbox_dir:
            sandbox_dir = self.sandbox_mgr.create_sandbox(session_id)
        
        # 构建 nsjail 命令
        nsjail_cmd = [
            "nsjail",
            "--mode", "o",
            "--disable_clone_newns",
            "--cwd", sandbox_dir,
            "--time_limit", str(timeout),
            "--max_cpus", "1",
            "--rlimit_as", "512",
            "--rlimit_fsize", "100",
            "--quiet",
            "--",
            "/bin/sh", "-c", command
        ]
        
        try:
            proc = await asyncio.create_subprocess_exec(
                *nsjail_cmd,
                stdout=asyncio.subprocess.PIPE,
                stderr=asyncio.subprocess.STDOUT
            )
            stdout, _ = await asyncio.wait_for(proc.communicate(), timeout=timeout + 5)
            return stdout.decode('utf-8', errors='replace'), proc.returncode
        except asyncio.TimeoutError:
            return "执行超时", -1
        except Exception as e:
            return f"执行错误: {str(e)}", -1
    async def terminate(self):
        """插件卸载时清理所有沙箱"""
        for session_id in list(self.sandbox_mgr.sandboxes.keys()):
            self.sandbox_mgr.destroy_sandbox(session_id)
